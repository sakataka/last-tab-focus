{
  "manifest_version": 3,
  "name": "Last Tab Focus",
  "version": "1.1.2",
  "description": "Returns to the previously used tab when you close the current tab",
  "author": "Chrome Extension Developer",
  
  "permissions": [
    "tabs",
    "storage"
  ],
  
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "minimum_chrome_version": "102"
}
